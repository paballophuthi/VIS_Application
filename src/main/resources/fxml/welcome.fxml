<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vis.controller.WelcomeController">
    <padding>
        <Insets top="50" right="50" bottom="50" left="50" />
    </padding>
    
    <Label text="Vehicle Information System" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
    
    <Label text="Manage your vehicles, track violations, and stay compliant" style="-fx-font-size: 14px;" />
    
    <Button fx:id="loginButton" text="Login" onAction="#handleLogin" prefWidth="120" prefHeight="35" />
    
    <Button fx:id="registerButton" text="Register" onAction="#handleRegister" prefWidth="120" prefHeight="35" />
    
    <Label text="© 2024 VIS - All Rights Reserved" style="-fx-font-size: 11px;">
        <padding>
            <Insets top="30" />
        </padding>
    </Label>
</VBox>