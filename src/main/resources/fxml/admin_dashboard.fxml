<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vis.controller.AdminDashboardController">
    <top>
        <VBox style="-fx-background-color: #2c3e50;">
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 10 20;">
                <Label fx:id="welcomeLabel" text="Welcome, Admin!" textFill="white" style="-fx-font-size: 14px;" />
                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <Button text="Profile" onAction="#handleProfile" style="-fx-background-color: #2980b9; -fx-text-fill: white;" />
                    <Button text="Refresh" onAction="#handleRefresh" style="-fx-background-color: #3498db; -fx-text-fill: white;" />
                    <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" />
                </HBox>
            </HBox>
        </VBox>
    </top>
    
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <!-- Dashboard Tab -->
            <Tab text="Dashboard">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <GridPane hgap="15" vgap="15">
                        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-alignment: center; -fx-border-radius: 5; -fx-border-color: #bdc3c7;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Total Users" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="totalUsersLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        </VBox>
                        
                        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-alignment: center; -fx-border-radius: 5; -fx-border-color: #bdc3c7;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Total Vehicles" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="totalVehiclesLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        </VBox>
                        
                        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-alignment: center; -fx-border-radius: 5; -fx-border-color: #bdc3c7;" GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <Label text="Total Violations" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="totalViolationsLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        </VBox>
                        
                        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-alignment: center; -fx-border-radius: 5; -fx-border-color: #bdc3c7;" GridPane.columnIndex="3" GridPane.rowIndex="0">
                            <Label text="Total Revenue" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="totalRevenueLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                        </VBox>
                        
                        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-alignment: center; -fx-border-radius: 5; -fx-border-color: #bdc3c7;" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Pending Violations" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="pendingViolationsLabel" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #f39c12;" />
                        </VBox>
                        
                        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-alignment: center; -fx-border-radius: 5; -fx-border-color: #bdc3c7;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Active Customers" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="activeUsersLabel" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        </VBox>
                        
                        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-alignment: center; -fx-border-radius: 5; -fx-border-color: #bdc3c7;" GridPane.columnIndex="2" GridPane.rowIndex="1">
                            <Label text="Workshops" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="totalWorkshopsLabel" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        </VBox>
                        
                        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-alignment: center; -fx-border-radius: 5; -fx-border-color: #bdc3c7;" GridPane.columnIndex="3" GridPane.rowIndex="1">
                            <Label text="Police Officers" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="totalPoliceLabel" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                        </VBox>
                    </GridPane>
                    
                    <HBox spacing="20">
                        <VBox spacing="10" HBox.hgrow="ALWAYS">
                            <Label text="Violations by Type" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                            <BarChart fx:id="violationChart">
                                <xAxis>
                                    <CategoryAxis label="Violation Type" />
                                </xAxis>
                                <yAxis>
                                    <NumberAxis label="Count" />
                                </yAxis>
                            </BarChart>
                        </VBox>
                        
                        <VBox spacing="10" HBox.hgrow="ALWAYS">
                            <Label text="User Distribution" style="-fx-font-weight: bold; -fx-font-size: 14px;" />
                            <PieChart fx:id="userDistributionChart" />
                        </VBox>
                    </HBox>
                    
                    <GridPane hgap="15" vgap="15">
                        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-alignment: center; -fx-border-radius: 5; -fx-border-color: #bdc3c7;" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <Label text="Average Fine Amount" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="avgFineLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" />
                        </VBox>
                        
                        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-alignment: center; -fx-border-radius: 5; -fx-border-color: #bdc3c7;" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <Label text="Resolution Rate" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="resolutionRateLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" />
                        </VBox>
                        
                        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-alignment: center; -fx-border-radius: 5; -fx-border-color: #bdc3c7;" GridPane.columnIndex="2" GridPane.rowIndex="2">
                            <Label text="Top Violation Type" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="topViolationTypeLabel" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #f39c12;" />
                        </VBox>
                        
                        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-alignment: center; -fx-border-radius: 5; -fx-border-color: #bdc3c7;" GridPane.columnIndex="3" GridPane.rowIndex="2">
                            <Label text="Monthly Growth" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="monthlyGrowthLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
                        </VBox>
                    </GridPane>
                </VBox>
            </Tab>
            
            <!-- Users Management Tab -->
            <Tab text="User Management">
                <VBox spacing="10" style="-fx-padding: 20;">
                    <HBox spacing="10">
                        <TextField fx:id="searchUserField" promptText="Search users..." HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="roleFilterComboBox" prefWidth="150" />
                        <Button text="Edit User" onAction="#handleEditUser" />
                        <Button text="Delete User" onAction="#handleDeleteUser" />
                        <Button text="Reset Password" onAction="#handleResetPassword" />
                    </HBox>
                    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS" />
                </VBox>
            </Tab>
            
            <!-- Vehicles Management Tab -->
            <Tab text="Vehicle Management">
                <VBox spacing="10" style="-fx-padding: 20;">
                    <HBox spacing="10">
                        <TextField fx:id="searchVehicleField" promptText="Search vehicles..." HBox.hgrow="ALWAYS" />
                        <Button text="View Details" onAction="#handleViewVehicle" />
                    </HBox>
                    <TableView fx:id="vehiclesTable" VBox.vgrow="ALWAYS" />
                </VBox>
            </Tab>
            
            <!-- Violations Tab -->
            <Tab text="Violations">
                <VBox spacing="10" style="-fx-padding: 20;">
                    <TableView fx:id="violationsTable" VBox.vgrow="ALWAYS" />
                    <HBox spacing="10">
                        <Button text="View Details" onAction="#handleViewViolation" />
                        <Button text="Mark as Paid" onAction="#handleMarkAsPaid" style="-fx-background-color: #27ae60; -fx-text-fill: white;" />
                    </HBox>
                </VBox>
            </Tab>
            
            <!-- Customer Queries Tab -->
            <Tab text="Customer Queries">
                <VBox spacing="10" style="-fx-padding: 20;">
                    <TableView fx:id="queriesTable" VBox.vgrow="ALWAYS" />
                    <HBox spacing="10">
                        <Button text="View Query" onAction="#handleViewQuery" />
                        <Button text="Respond" onAction="#handleRespondToQuery" style="-fx-background-color: #3498db; -fx-text-fill: white;" />
                    </HBox>
                </VBox>
            </Tab>
            
            <!-- Reports Tab -->
            <Tab text="Reports">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <Label text="Generate Reports" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                    <Button text="Generate Users Report" onAction="#handleGenerateUsersReport" prefWidth="250" style="-fx-background-color: #3498db; -fx-text-fill: white;" />
                    <Button text="Generate Vehicles Report" onAction="#handleGenerateVehiclesReport" prefWidth="250" style="-fx-background-color: #3498db; -fx-text-fill: white;" />
                    <Button text="Generate Violations Report" onAction="#handleGenerateViolationsReport" prefWidth="250" style="-fx-background-color: #3498db; -fx-text-fill: white;" />
                    <Button text="Generate Revenue Report" onAction="#handleGenerateRevenueReport" prefWidth="250" style="-fx-background-color: #3498db; -fx-text-fill: white;" />
                    
                    <Label text="System Utilities" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-margin-top: 30px;" />
                    <Button text="Backup Database" onAction="#handleBackupDatabase" prefWidth="250" style="-fx-background-color: #f39c12; -fx-text-fill: white;" />
                    <Button text="Export Data" onAction="#handleExportData" prefWidth="250" />
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>