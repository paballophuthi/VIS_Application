<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.vis.controller.RegisterController">
    <padding>
        <Insets top="30" right="50" bottom="30" left="50" />
    </padding>
    
    <Label text="Create New Account" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
    
    <GridPane alignment="CENTER" hgap="10" vgap="10">
        <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="usernameField" promptText="Choose a username" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        
        <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="emailField" promptText="Enter your email" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        
        <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="fullNameField" promptText="Enter your full name" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        
        <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <PasswordField fx:id="passwordField" promptText="Create a password" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        
        <Label text="Confirm Password:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="4" />
        
        <Label text="Role:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
        <ComboBox fx:id="roleComboBox" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="5" />
    </GridPane>
    
    <Button text="Register" onAction="#handleRegister" prefWidth="150" prefHeight="35" />
    
    <Hyperlink text="Already have an account? Login here" onAction="#handleBackToLogin" />
    
    <Label text="* Required fields" style="-fx-font-size: 11px;" />
</VBox>